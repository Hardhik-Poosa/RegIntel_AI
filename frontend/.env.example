# ── RegIntel AI — Frontend environment variables ─────────────────────────────
# Copy this to .env.production (for production builds) or .env.local (for local overrides).
# NEVER commit files containing real secrets to git.

# Backend API base URL — must end with /api/v1
# Development (via Vite proxy):  leave unset, proxy handles /api → localhost:8000
# Production (Vercel → Railway): set to your Railway backend URL
VITE_API_URL=https://your-backend.railway.app/api/v1
